# Mobile app API configuration
# The backend API base URL — no gateway name in source code.
# Injected at build time by react-native-dotenv (see babel.config.js).

# Development (Android emulator uses 10.0.2.2 to reach host machine)
# API_URL=http://10.0.2.2:3000/api

# iOS Simulator
# API_URL=http://localhost:3000/api

# Production (HTTPS required for PCI DSS)
# API_URL=https://your-production-api.com/api

API_URL=http://10.0.2.2:3000/api