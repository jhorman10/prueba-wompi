{
  "name": "prueba-wompi-mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.5",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.26.0",
    "react-redux": "^9.1.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "^0.86.0",
    "@react-native/eslint-config": "^0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "^0.86.0",
    "@react-native/typescript-config": "^0.86.0",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "react-test-renderer": "19.2.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|@react-native-async-storage|react-native-.*|immer|@reduxjs/toolkit|redux|redux-persist|redux-thunk|react-native-encrypted-storage|react-redux|use-sync-external-store)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/store/store.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
