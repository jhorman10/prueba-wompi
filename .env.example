# Root Environment Configuration
# Copy this file to .env and fill in your values.
# See backend/.env.example and mobile/.env for layer-specific config.

# --- Mobile ---
# The backend API base URL the mobile app connects to.
# API_URL=http://localhost:3000/api

# --- Backend ---
# Application
# PORT=3000
# NODE_ENV=development
# GATEWAY_URL=https://sandbox-gateway.example.com
# GATEWAY_API_KEY=your-sandbox-api-key
