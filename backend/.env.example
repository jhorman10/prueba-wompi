# Backend Environment Configuration
# Copy this file to .env and fill in your values.

# Application
PORT=3000
NODE_ENV=development

# Payment Gateway
# GATEWAY_MODE selects how the backend talks to the gateway:
#   simulate  -> returns canned responses locally (default, no network calls)
#   live      -> performs REAL HTTP calls to GATEWAY_URL using GATEWAY_API_KEY
# Tests run with GATEWAY_MODE=simulate so they never hit the network.
GATEWAY_MODE=simulate

# The sandbox gateway base URL (keep this in your gitignored .env only).
# Example: https://sandbox.example-payments.com
GATEWAY_URL=https://sandbox-gateway.example.com

# API key sent as `Authorization: Bearer <GATEWAY_API_KEY>` on every live call.
GATEWAY_API_KEY=your-sandbox-api-key

# CORS — comma-separated whitelist of allowed origins for the API.
# Leave unset to allow any origin (dev only). For production, set explicit origins.
CORS_ORIGINS=http://localhost:8081
